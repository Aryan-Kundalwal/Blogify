<!DOCTYPE html>
<html lang="en">

<head>
  <%- include('./partials/head') %>
  <title>Home Page</title>

  <style>
    body {
      background: #f5f7fb;
    }

    .hero {
      text-align: center;
      padding: 50px 20px;
    }

    .hero h1 {
      font-size: 3rem;
      font-weight: 800;
      color: #111827;
    }

    .hero p {
      color: #6b7280;
      font-size: 1.1rem;
    }

    .blog-card {
      border: none;
      border-radius: 18px;
      overflow: hidden;
      box-shadow: 0 8px 25px rgba(0, 0, 0, 0.08);
      transition: 0.3s ease;
      height: 100%;
      background: white;
    }

    .blog-card:hover {
      transform: translateY(-8px);
    }

    .image-container {
      width: 100%;
      height: 250px;
      overflow: hidden;
      background: #e5e7eb;
    }

    .blog-image {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center;
      display: block;
    }

    .card-body {
      display: flex;
      flex-direction: column;
      padding: 20px;
    }

    .card-title {
      font-weight: 700;
      color: #111827;
      min-height: 60px;
    }

    .btn-view {
      margin-top: auto;
      width: 100%;
      border-radius: 10px;
      font-weight: 600;
    }
  </style>
</head>

<body>

  <%- include('./partials/nav') %>

  <div class="hero">
    <h1>Welcome to Blogify</h1>
    <p>Discover stories, ideas and insights from our community.</p>
  </div>

  <div class="container mb-5">

    <div class="row g-4">

      <% blogs.forEach(blog => { %>

      <div class="col-lg-4 col-md-6 col-sm-12">

        <div class="card blog-card">

          <div class="image-container">
            <img
              src="<%= blog.coverImageURL %>"
              class="blog-image"
              alt="<%= blog.title %>">
          </div>

          <div class="card-body">

            <h5 class="card-title">
              <%= blog.title %>
            </h5>

            <a
              href="/blog/<%= blog._id %>"
              class="btn btn-dark btn-view">
              Read More
            </a>

          </div>

        </div>

      </div>

      <% }) %>

    </div>

  </div>

  <%- include('./partials/script') %>

</body>

</html>