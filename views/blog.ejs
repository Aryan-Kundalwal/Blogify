<!DOCTYPE html>
<html lang="en">

<head>
  <%- include('./partials/head') %>
  <title><%= blog.title %></title>

  <style>
    body {
      background: #f5f7fb;
      color: #111827;
    }

    .blog-container {
      max-width: 900px;
      margin: 40px auto;
    }

    .blog-card {
      background: #fff;
      border-radius: 20px;
      padding: 40px;
      box-shadow: 0 10px 30px rgba(0,0,0,0.08);
    }

    .blog-title {
      font-size: 2.8rem;
      font-weight: 800;
      color: #111827;
      margin-bottom: 25px;
    }

    .cover-image {
      width: 100%;
      border-radius: 16px;
      max-height: 500px;
      object-fit: cover;
    }

    .author-box {
      display: flex;
      align-items: center;
      gap: 15px;
      margin-top: 25px;
      padding: 15px;
      border-radius: 12px;
      background: #f8fafc;
    }

    .author-box img,
    .comment-user img {
      width: 50px;
      height: 50px;
      border-radius: 50%;
      object-fit: cover;
    }

    .author-name {
      font-weight: 700;
      color: #111827;
    }

    .blog-content {
      margin-top: 30px;
      color: #111827;
      font-size: 18px;
      line-height: 1.8;
      white-space: pre-wrap;
    }

    .comment-section {
      margin-top: 30px;
      background: white;
      padding: 30px;
      border-radius: 20px;
      box-shadow: 0 5px 20px rgba(0,0,0,0.05);
    }

    .comment-card {
      background: #f8fafc;
      border-radius: 12px;
      padding: 15px;
      margin-top: 15px;
      color: #111827;
    }

    .comment-user {
      display: flex;
      align-items: center;
      gap: 10px;
      margin-bottom: 10px;
      font-weight: 600;
    }

    .form-control {
      border-radius: 10px;
    }

    pre {
      white-space: pre-wrap;
      font-family: inherit;
      margin: 0;
      color: #111827;
    }
  </style>
</head>

<body>

  <%- include('./partials/nav') %>

  <div class="container blog-container">

    <div class="blog-card">

      <h1 class="blog-title">
        <%= blog.title %>
      </h1>

      <img src="<%= blog.coverImageURL %>" class="cover-image">

      <div class="author-box">
        <img src="<%= blog.createdBy.profileImageURL %>">

        <div>
          <div class="author-name">
            <%= blog.createdBy.fullName %>
          </div>
          <small class="text-muted">Author</small>
        </div>
      </div>

      <div class="blog-content">
        <%= blog.body %>
      </div>

    </div>

    <div class="comment-section">

      <h3>Comments (<%= comments.length %>)</h3>

      <% if (locals.user) { %>

      <form action="/blog/comment/<%= blog._id %>" method="post">

        <div class="mb-3">
          <input
            type="text"
            name="content"
            class="form-control"
            placeholder="Write a comment...">
        </div>

        <button type="submit" class="btn btn-dark">
          Add Comment
        </button>

      </form>

      <% } %>

      <% comments.forEach(comment => { %>

      <div class="comment-card">

        <div class="comment-user">
          <img src="<%= comment.createdBy.profileImageURL %>">

          <span>
            <%= comment.createdBy.fullName %>
          </span>
        </div>

        <pre><%= comment.content %></pre>

      </div>

      <% }) %>

    </div>

  </div>

  <%- include('./partials/script') %>

</body>
</html>